#!/bin/sh
# Bellows post-run cargo checks gate (slice X1, parameterised by
# ADR-0004).
#
# The clippy and test commands are NOT baked into this script. Bellows
# snapshots the target repo's CI workflow (.github/workflows/*.yml)
# at workspace::prepare time and passes the extracted commands here
# via two env vars:
#
#   BELLOWS_CLIPPY_CMD  — complete `cargo clippy ...` invocation.
#   BELLOWS_TEST_CMD    — complete `cargo test ...` invocation.
#
# When the workflow can't be parsed, bellows substitutes its
# `[gates].*_flags` fallback before invoking us. Either way, the
# commands arrive here as complete shell-evaluable strings and we
# eval them verbatim, so the gate runs whatever CI runs.
#
# `BELLOWS_WORKSPACE` overrides the default `/workspace` cwd so the
# same script can be exercised under tests without a Docker bind-
# mount in place.
#
# Each check's stdout+stderr is captured to its own file in the
# workspace bind mount so the runner can attribute failures to the
# right check in the PR log comment. Exit codes are written to a tiny
# results file. The container's overall exit follows the worst exit
# code seen (clippy failure beats test failure).
#
# The runner is responsible for reading these files after the
# container exits, then removing them so they don't end up in any
# subsequent commit.

set -u

WORKSPACE_DIR="${BELLOWS_WORKSPACE:-/workspace}"
cd "$WORKSPACE_DIR" || exit 64

CLIPPY_OUTPUT="$WORKSPACE_DIR/.bellows-cargo-clippy-output"
TEST_OUTPUT="$WORKSPACE_DIR/.bellows-cargo-test-output"
RESULTS="$WORKSPACE_DIR/.bellows-cargo-checks-results"

# Truncate any leftovers from a prior run (defensive — Bellows removes
# these on the host between runs, but a partial file should never block
# the gate from producing fresh output).
: > "$CLIPPY_OUTPUT"
: > "$TEST_OUTPUT"
: > "$RESULTS"

CLIPPY_CMD="${BELLOWS_CLIPPY_CMD:-cargo clippy --all-targets --all-features -- -D warnings}"
TEST_CMD="${BELLOWS_TEST_CMD:-cargo test --all-targets --all-features}"

# Echo the actual command before executing so an operator watching the
# container output sees the verbatim posture being applied. Bellows
# emits its own provenance line (parsed vs fallback) at gate-phase
# start; this echo is the per-step confirmation that the script
# received and is running what bellows handed it.
echo "+ $CLIPPY_CMD"
sh -c "$CLIPPY_CMD" >"$CLIPPY_OUTPUT" 2>&1
CLIPPY_EXIT=$?

if [ $CLIPPY_EXIT -eq 0 ]; then
    echo "+ $TEST_CMD"
    sh -c "$TEST_CMD" >"$TEST_OUTPUT" 2>&1
    TEST_EXIT=$?
    TEST_RECORDED=$TEST_EXIT
else
    echo "(skipped — clippy failed with exit $CLIPPY_EXIT)" >"$TEST_OUTPUT"
    TEST_EXIT=0       # used only for the container's overall exit
    TEST_RECORDED=    # empty = "did not run", parsed by the runner
fi

# Tiny key=value results file the runner parses after the container
# exits. test_exit is empty when the test step did not run.
{
    echo "clippy_exit=$CLIPPY_EXIT"
    echo "test_exit=$TEST_RECORDED"
} >"$RESULTS"

# Tee the captured outputs to stdout so an operator watching `bellows
# run` in their terminal sees what cargo said live, not just after
# the container exits.
echo "=== cargo clippy ==="
cat "$CLIPPY_OUTPUT"
echo "=== cargo test ==="
cat "$TEST_OUTPUT"

# Container exit follows the worst of the two exit codes — non-zero
# from either check propagates so the runner sees the gate as failed.
if [ $CLIPPY_EXIT -ne 0 ]; then
    exit $CLIPPY_EXIT
fi
exit $TEST_EXIT
