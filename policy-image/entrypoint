#!/bin/sh
# Bellows policy-image entrypoint.
#
# Runs once per container start. Copies the baked skills + CLAUDE.md from
# /opt/bellows-policy/ into /root/.claude/ (where the credentials volume
# is mounted) so they layer with the persisted OAuth tokens, then exec's
# run-agent.
#
# Idempotent: subsequent runs overwrite any older copies in the volume,
# which is what we want — the policy image is the source of truth for
# skills + CLAUDE.md, the volume is the source of truth for credentials.

set -eu

mkdir -p /root/.claude/skills

# Use cp -r with a trailing /. so we copy CONTENTS, not the directory
# itself, regardless of whether /root/.claude/skills already exists.
cp -r /opt/bellows-policy/skills/. /root/.claude/skills/
cp /opt/bellows-policy/CLAUDE.md /root/.claude/CLAUDE.md

# Workaround for Claude Code v2.1: setup-auth created /root/.claude.json
# but the credentials volume only mounts /root/.claude/ (the directory).
# .claude.json (sibling file) is NOT in the volume, so it's lost on
# container exit. Claude Code itself stashes a backup inside
# /root/.claude/backups/ (which IS in the volume); restore it on each
# start so Claude Code finds its config.
if [ ! -f /root/.claude.json ]; then
    LATEST_BACKUP=$(ls -t /root/.claude/backups/.claude.json.backup.* 2>/dev/null | head -n 1 || true)
    if [ -n "$LATEST_BACKUP" ]; then
        cp "$LATEST_BACKUP" /root/.claude.json
    fi
fi

exec /usr/local/bin/run-agent "$@"
