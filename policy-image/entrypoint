#!/bin/sh
# Bellows policy-image root-mode prep.
#
# Runs as root on container start (the Dockerfile does NOT set
# `USER bellows`; that drop happens here instead). Two responsibilities:
#
# 1. Chown the cache-volume mount points so the bellows user can write
#    to them. Docker creates a fresh named volume's `_data` directory
#    as `root:root` mode 0755 whenever the mount target does not exist
#    in the image — which is the case for `/workspace/target` (shadowed
#    by the workspace bind mount) and `/usr/local/cargo/registry`
#    (cargo creates it lazily; the base image doesn't ship it). Without
#    this chown, cargo's first write into either path fails with EACCES
#    on a fresh repo / fresh host.
#
# 2. Drop to the bellows user via `runuser` and exec the user-mode
#    continuation (either /usr/local/bin/entrypoint-user for the
#    default agent run, or whatever override was passed — e.g.
#    /usr/local/bin/run-cargo-checks for the cargo-checks gate).
#    Claude Code refuses to honour `--dangerously-skip-permissions`
#    when running as root, so the agent invocation MUST run as bellows.

set -eu

# Top-level chown is sufficient: on first attach the volume's _data is
# the empty mount-point directory itself, and cargo (running as bellows)
# creates everything underneath as bellows. -R would needlessly walk a
# warm target/ tree on every subsequent run.
chown bellows:bellows /workspace/target /usr/local/cargo/registry

if [ "$#" -eq 0 ]; then
    set -- /usr/local/bin/entrypoint-user
fi

exec runuser -u bellows -- "$@"
