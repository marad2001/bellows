#!/bin/sh
# Bellows agent entry (slice 3 - real Claude Code).
#
# Reads the kickoff prompt Bellows wrote into the workspace before
# the container started, removes the prompt file so it doesn't leak
# into the resulting commit, and exec's `claude -p` with the prompt.
#
# Slice 2's stub-marker behaviour is gone; the agent is responsible
# for whatever changes end up in the workspace.

set -eu

KICKOFF=/workspace/.bellows-kickoff.md

if [ ! -f "$KICKOFF" ]; then
    echo "bellows: missing kickoff prompt at $KICKOFF" >&2
    exit 2
fi

PROMPT="$(cat "$KICKOFF")"
rm -f "$KICKOFF"

# --dangerously-skip-permissions bypasses Claude Code's per-tool approval
# prompts. The container is the sandbox boundary (Docker isolation,
# /workspace-only mount), so the per-tool gate is redundant and would
# otherwise hang headlessly waiting for a human to approve each Write.
exec claude --dangerously-skip-permissions -p "$PROMPT"
